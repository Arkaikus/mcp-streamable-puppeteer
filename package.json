{
  "name": "mcp-streamable-puppeteer",
  "version": "0.1.0",
  "description": "Streamable HTTP MCP server with Puppeteer browser automation for LM Studio (Bun)",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test tests/",
    "test:mcp": "bun test tests/mcp-integration.test.ts",
    "test:smoke": "bun run tests/e2e-smoke.ts",
    "test:smoke:peoople": "bun run tests/e2e-smoke-peoople.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "^1.3.10",
    "openai": "^4.77.0"
  },
  "dependencies": {
    "@hono/mcp": "^0.2.4",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "hono": "^4.6.0",
    "puppeteer-core": "^24.0.0",
    "zod": "^3.24.0"
  }
}
